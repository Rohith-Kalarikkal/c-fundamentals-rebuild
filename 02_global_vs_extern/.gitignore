# ==============================================================================
# Git Ignore for Global vs Extern Demo
# ==============================================================================

# --- Build Artefacts ---
# Ignore the entire build directory (objects and binaries)
build/

# Compiled Executables (Windows)
*.exe
*.out
app.exe
app

# Object files and Libraries
*.o
*.obj
*.a
*.lib

# Debug symbols and IDE folders
.vscode/
*.dSYM/
.DS_Store

# Intermediate build files
*.i
*.s